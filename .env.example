# ============================================================
# LOCAL AI STACK — Variáveis de Ambiente
# ============================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores abaixo
#   3. NUNCA commite o arquivo .env no Git!
# ============================================================

# ------------------------------------------------------------
# HUGGING FACE TOKEN (OBRIGATÓRIO para modelos privados/gated)
# ------------------------------------------------------------
# Como obter:
#   1. Acesse https://huggingface.co/settings/tokens
#   2. Clique em "New token" → selecione "Read"
#   3. Copie e cole aqui
#
# O token é necessário para baixar modelos como Qwen2.5-Instruct
# que exigem aceite de licença no site do HuggingFace.
# ------------------------------------------------------------
HF_TOKEN=hf_SeuTokenAqui

# ------------------------------------------------------------
# MODELO vLLM (pode trocar conforme sua GPU — veja docs/hardware.md)
# ------------------------------------------------------------
# Exemplos:
#   Qwen/Qwen2.5-3B-Instruct-AWQ   (3B, ~2GB VRAM, GPU 6GB+)
#   Qwen/Qwen2.5-7B-Instruct-AWQ   (7B, ~5GB VRAM, GPU 8GB+)
#   Qwen/Qwen2.5-14B-Instruct-AWQ  (14B, ~10GB VRAM, GPU 12GB+)
#   microsoft/phi-2                 (2.7B, sem necessidade de token)
# ------------------------------------------------------------
VLLM_MODEL=Qwen/Qwen2.5-3B-Instruct-AWQ

# Nome interno do modelo (como aparece no OpenWebUI)
SERVED_MODEL_NAME=qwen
